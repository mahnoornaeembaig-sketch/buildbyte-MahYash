import { useState } from 'react';
import { supabase } from '../lib/supabase';

export default function ReviewForm() {
  const [formData, setFormData] = useState({ name: '', number: '', review: '' });
  const [status, setStatus] = useState('');

  const handleSubmit = async (e) => {
    e.preventDefault();
    
    // Insert into Supabase
    const { error } = await supabase
      .from('reviews')
      .insert([{ 
        display_name: formData.name, 
        phone_number: formData.number, 
        review_text: formData.review 
      }]);

    if (error) {
      setStatus('Error sending review.');
    } else {
      setStatus('Review sent successfully!');
      setFormData({ name: '', number: '', review: '' });
    }
  };

  return (
    <form onSubmit={handleSubmit} className="p-4 border rounded bg-navy-deep/50">
      <h2 className="text-xl mb-4 text-paper">Submit a Review</h2>
      <input 
        className="w-full mb-2 p-2" 
        placeholder="Name" 
        value={formData.name}
        onChange={(e) => setFormData({...formData, name: e.target.value})} 
      />
      <input 
        className="w-full mb-2 p-2" 
        placeholder="Number" 
        value={formData.number}
        onChange={(e) => setFormData({...formData, number: e.target.value})} 
      />
      <textarea 
        className="w-full mb-2 p-2" 
        placeholder="Your Review" 
        value={formData.review}
        onChange={(e) => setFormData({...formData, review: e.target.value})} 
      />
      <button className="bg-amber p-2 w-full text-navy font-bold">Submit</button>
      {status && <p className="mt-2 text-paper">{status}</p>}
    </form>
  );
}